      "supportsTablet": true,
      "bundleIdentifier": "com.tiborkulcar.timetoleave"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      }
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "ce6855d3-c76c-4f00-974e-1e1e19e0392d"
      }
    }
  }
}
